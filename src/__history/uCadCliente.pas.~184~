      EDT_IbgeCid.Text     := frmDatamodulo.dsClientes.DataSet.FieldByName('Ibge_cidade').AsString;
      EDT_Uf.Text          := frmDatamodulo.dsClientes.DataSet.FieldByName('Sigla_uf').AsString;
